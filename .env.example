# Copy to .env and fill in. Retrieval + out-of-scope rejection work WITHOUT any
# key (local embeddings + BM25). A Portkey key adds LLM routing + answer synthesis.

# --- Embeddings (retrieval) ---
# "local" = open-source sentence-transformers model, no key needed (default).
# "portkey" = hosted embeddings via Portkey (needs PORTKEY_API_KEY + EMBED_MODEL).
EMBED_BACKEND=local
LOCAL_EMBED_MODEL=all-MiniLM-L6-v2
EMBED_MODEL=text-embedding-3-small   # only used when EMBED_BACKEND=portkey

# --- LLM (routing + answer synthesis), via Portkey ---
# Your Portkey API key.
PORTKEY_API_KEY=

# Portkey gateway base URL (should end in /v1).
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# Chat model slug. With many gateways the provider is encoded in the slug, e.g.
#   @aws-bedrock-use2/us.anthropic.claude-sonnet-4-5-20250929-v1:0
# in which case just the API key + base URL + model is enough (no keys below).
LLM_MODEL=gpt-4o-mini

# --- Optional: only if your key is NOT pre-bound to a provider ---
# A Portkey "virtual key"...
PORTKEY_VIRTUAL_KEY=
# ...OR a provider name + that provider's raw key.
PORTKEY_PROVIDER=
PORTKEY_PROVIDER_API_KEY=

# --- Tuning ---
# Hybrid retrieval (BM25 + dense via RRF). Set HYBRID=0 for dense-only.
HYBRID=1
# Out-of-scope cosine threshold. MUST be re-tuned per embedding model on real
# questions: `python -m eval.run_eval --sweep`. 0.31 is tuned for all-MiniLM-L6-v2.
OOS_COSINE_MIN=0.31
