# Copy to .env and fill in. The app runs WITHOUT these (lexical BM25 fallback),
# but adding a Portkey key turns on: LLM routing, embedding+FAISS retrieval,
# robust out-of-scope detection, and grounded answer synthesis.

# --- Required for LLM + embeddings mode ---
# Your Portkey API key.
PORTKEY_API_KEY=

# Portkey gateway base URL (should end in /v1). If your provider key/config is
# attached to the Portkey API key server-side, this + the key + a model is enough.
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# Chat model slug used for routing + answering (provider-specific).
# Examples: gpt-4o-mini, gpt-4.1-mini, claude-3-5-sonnet-latest
LLM_MODEL=gpt-4o-mini

# Embedding model slug used to build the FAISS index + embed queries.
# Must be an embeddings-capable model on your provider.
# Examples: text-embedding-3-small, text-embedding-3-large
EMBED_MODEL=text-embedding-3-small

# --- Optional: only if your key is NOT pre-bound to a provider ---
# Provide a Portkey "virtual key"...
PORTKEY_VIRTUAL_KEY=
# ...OR a provider name + that provider's raw key.
PORTKEY_PROVIDER=
PORTKEY_PROVIDER_API_KEY=
